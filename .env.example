# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Base de datos ──────────────────────────────────────────────────────────
# Neon.tech — obtener en https://neon.tech
DATABASE_URL=postgresql+asyncpg://user:password@host/conflur

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── IA — Anthropic ─────────────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modelo por agente (default: claude-sonnet-4-6)
NOTES_MODEL=claude-sonnet-4-6
CEO_MODEL=claude-sonnet-4-6
CONTENT_MODEL=claude-sonnet-4-6
CS_MODEL=claude-sonnet-4-6
FINANCE_MODEL=claude-sonnet-4-6

# ─── Knowledge Module ───────────────────────────────────────────────────────
# KM compartido de plataforma — obtener la URL del proyecto knowledge_module en Neon
KM_DATABASE_URL=postgresql+asyncpg://user:password@host/knowledge_module
KM_TENANT_ID=eia1

# ─── Billing ────────────────────────────────────────────────────────────────
# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MercadoPago — https://www.mercadopago.com/developers
MERCADOPAGO_ACCESS_TOKEN=TEST-...
MERCADOPAGO_WEBHOOK_SECRET=...

# ─── Telegram (CEO-agente) ───────────────────────────────────────────────────
# Crear bot con @BotFather
TELEGRAM_BOT_TOKEN=
# Tu chat ID personal (obtener con @userinfobot)
TELEGRAM_CHAT_ID=

# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
