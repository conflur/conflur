# ─── Backend API ────────────────────────────────────────────────────────────
# URL del backend FastAPI (Railway en prod, localhost en dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── NextAuth ───────────────────────────────────────────────────────────────
# Firma la sesión propia de NextAuth. Es independiente del NEXTAUTH_SECRET del
# backend (el backend valida sus propios access tokens). Puede ser el mismo valor.
NEXTAUTH_SECRET=your-secret-here
# URL pública del frontend (Vercel en prod, localhost en dev)
NEXTAUTH_URL=http://localhost:3000
